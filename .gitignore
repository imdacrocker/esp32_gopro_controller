# Prerequisites
*.d

# Object files
*.o
*.ko
*.obj
*.elf

# Linker output
*.ilk
*.map
*.exp

# Precompiled Headers
*.gch
*.pch

# Libraries
*.lib
*.a
*.la
*.lo

# Shared objects (inc. Windows DLLs)
*.dll
*.so
*.so.*
*.dylib

# Executables
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex

# Debug files
*.dSYM/
*.su
*.idb
*.pdb

# Kernel Module Compile Results
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# debug information files
*.dwo
# ESP-IDF build artifacts — match in any app dir under apps/*
sdkconfig
sdkconfig.old
managed_components/
build/

# Registry components vendored from GitHub by the SessionStart hook (the web
# container's network policy blocks the ESP Component Registry). Session-local,
# never committed.
/apps/main/components/joltwallet__littlefs/
/apps/main/components/espressif__cjson/

/.vscode
# Claude Code: ignore personal/local config, but track the shared SessionStart
# hook and project settings so web sessions pick them up after merge.
/.claude/*
!/.claude/settings.json
!/.claude/hooks/
/.claude/settings.local.json
/apps/recovery/.vscode
/apps/main/.vscode

/release/
